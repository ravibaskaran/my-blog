---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const resume = await getEntry("pages", "resume");

if (!resume) {
  throw new Error(
    "Missing content entry: `resume.md` or `resume.mdx` in `src/content/pages/`"
  );
}

const { Content } = await render(resume);
---

<Layout
  title={`${resume.data.title} | ${config.site.title}`}
  description={resume.data.description}
  ogImage={resume.data.ogImage}
  canonicalURL={resume.data.canonicalURL}
>
  <Header />

  <Breadcrumb />

  <Main pageTitle={resume.data.title} class="app-prose">
    <Content />
  </Main>

  <Footer />
</Layout>
