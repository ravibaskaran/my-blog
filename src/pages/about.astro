---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { authorProfile } from "@/data/author.js";

const about = await getEntry("pages", "about");

if (!about) {
  throw new Error(
    "Missing content entry: `about.md` or `about.mdx` in `src/content/pages/`"
  );
}

const { Content } = await render(about);

const authorUrl = new URL(authorProfile.profilePath, config.site.url).href;
const authorImage = new URL(authorProfile.image, config.site.url).href;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: about.data.title,
  url: new URL("/about/", config.site.url).href,
  description: about.data.description,
  mainEntity: {
    "@type": "Person",
    name: authorProfile.name,
    url: authorUrl,
    image: authorImage,
    description: authorProfile.summary,
    email: authorProfile.email,
    jobTitle: authorProfile.title,
    sameAs: authorProfile.sameAs,
    knowsAbout: authorProfile.expertise,
  },
};
---

<Layout
  title={`${about.data.title} | ${config.site.title}`}
  description={about.data.description}
  ogImage={about.data.ogImage}
  canonicalURL={about.data.canonicalURL}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
  </Fragment>

  <Header />

  <Breadcrumb />

  <Main pageTitle={about.data.title} class="app-prose">
    <Content />
  </Main>

  <Footer />
</Layout>
