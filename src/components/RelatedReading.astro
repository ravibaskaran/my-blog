---
type RelatedPost = {
  title: string;
  url: string;
};

type Props = {
  posts: RelatedPost[];
};

const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="not-prose mt-10">
      <h2 class="text-foreground text-lg font-semibold">Related reading</h2>
      <ul class="mt-3 space-y-3">
        {posts.map(post => (
          <li>
            <a
              href={post.url}
              class="text-accent underline underline-offset-4 transition-colors hover:opacity-80"
            >
              {post.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
